<?php
include ('Include\config.php'); // Include database connection

session_start(); // Start the session to store user data

$error = ''; // Initialize the error variable

if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['vusername'], $_POST['vpassword'])) {
    // Sanitize user input
    $user = htmlspecialchars(trim($_POST['vusername']));
    $pass = $_POST['vpassword'];

    // Use prepared statements to prevent SQL injection
    $stmt = $con->prepare("SELECT * FROM vendor WHERE username = ?");
    $stmt->bind_param("s", $user);
    $stmt->execute();
    $result = $stmt->get_result();

    if ($result->num_rows > 0) {
        $row = $result->fetch_assoc();
        if (password_verify($pass, $row['password'])) {  // Successful login
            $_SESSION['vendor_id'] = $row['vendor_id']; // Use database value for accuracy
            echo '<pre>';
            print_r($_SESSION['vendor_id']);
            echo '</pre>';
            header("Location: /AgriHub/AgriHub/index.php"); // Redirect to dashboard or main page
            exit();
        } else {
            // Invalid credentials
            $error = "Invalid username or password.";
        }
    } else {
        // Invalid credentials
        $error = "Invalid username or password.";
    }

    $stmt->close();
}
?>

